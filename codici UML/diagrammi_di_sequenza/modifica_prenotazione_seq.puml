@startuml

actor Cliente
participant "<<Boundary>>\nInterfacciaPrenotazione" as B
participant "<<Controller>>\nGestorePrenotazione" as C
participant "<<Entity>>\n:StanzaVecchia" as P
participant "<<Entity>>\n:StanzaNuova" as S

Cliente -> B : modifica()
B -> C : elencaPrenotazioniCliente()
C -> C : trovaPerId(idCliente)
C --> C : prenotazioni
C --> B : lista prenotazioni
Cliente -> B : sceglie prenotazione
B -> C : modifica(idCliente, idPrenotazione)
C -> C : verifica tempo mancante 

alt Mancano < 24h
    C -> B : mostraErrore()
    B --> Cliente : modifica non eseguibile
   
else Mancano >= 24h
    Cliente -> B : inserisce dati
    B -> C : modificaPrenotazione(idPrenotazione, idCliente,\n nuovo_giorno, nuova_ora)
    C -> C : trovaStanza(idStanza)
    C --> C : stanza
    C -> S : isDisponibile()

alt Stanza Disponibile
    C -> S : setStato("occupata")
    C -> P : setStato("libera")
    C --> B  
    B --> Cliente : modifica eseguita con successo

else Stanza Non Disponibile
    C -> B : mostraErrore(stanza non disponibile)
    B --> Cliente : modifica non eseguibile

end
end   
@enduml